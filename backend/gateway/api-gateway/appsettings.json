{
  "Jwt": {
    "Issuer": "PlatformApp",
    "Audience": "PlatformApp.Client",
    "SigningKey": "platform-app-local-signing-key-2026"
  },
  "ReverseProxy": {
    "Routes": {
      "catalog": {
        "ClusterId": "platform-app-api",
        "Match": {
          "Path": "/api/catalog-{**catch-all}"
        }
      },
      "api": {
        "ClusterId": "platform-app-api",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      },
      "basket": {
        "ClusterId": "platform-app-api",
        "Match": {
          "Path": "/Basket/{**catch-all}"
        }
      },
      "orders": {
        "ClusterId": "platform-app-api",
        "Match": {
          "Path": "/Order/{**catch-all}"
        }
      },
      "account": {
        "ClusterId": "platform-app-api",
        "Match": {
          "Path": "/Account/{**catch-all}"
        }
      },
      "manage": {
        "ClusterId": "platform-app-api",
        "Match": {
          "Path": "/Manage/{**catch-all}"
        }
      },
      "admin": {
        "ClusterId": "platform-app-api",
        "Match": {
          "Path": "/Admin/{**catch-all}"
        }
      },
      "user": {
        "ClusterId": "platform-app-api",
        "Match": {
          "Path": "/User/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "platform-app-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://platform-app-api:8080/"
          }
        }
      }
    }
  }
}
